<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_dashboard_premium">

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilBuscar"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:hint="Buscar producto..."
        android:textColorHint="#B0BEC5"
        app:boxStrokeColor="#E0E0E0"
        app:hintTextColor="#FFFFFF"
        app:boxStrokeWidth="1dp"
        app:boxStrokeWidthFocused="2dp"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etBuscarProducto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF" />
    </com.google.android.material.textfield.TextInputLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvProductos"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:clipToPadding="false"
        android:paddingBottom="16dp"
        app:layout_constraintBottom_toTopOf="@+id/cardResumenContable"
        app:layout_constraintTop_toBottomOf="@id/tilBuscar" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardResumenContable"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@android:color/transparent"
        app:strokeWidth="1dp"
        app:strokeColor="#26FFFFFF"
        android:layout_marginTop="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tilBuscar"
        app:layout_constraintVertical_bias="1.0"
        app:layout_constrainedHeight="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_ghost_gradient"
            android:paddingTop="12dp"
            android:paddingHorizontal="16dp"
            android:paddingBottom="32dp">

            <androidx.constraintlayout.widget.Group
                android:id="@+id/layoutDetalleColapsable"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone"
                app:constraint_referenced_ids="headerCarrito,rvResumenApuesta,dividerCarrito"
                tools:visibility="visible" />

            <RelativeLayout
                android:id="@+id/headerCarrito"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CARRITO DE PEDIDO"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="11sp"
                    android:letterSpacing="0.1"/>

                <TextView
                    android:id="@+id/btnLimpiarApuesta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="LIMPIAR"
                    android:textColor="#FF5252"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="4dp"
                    android:paddingVertical="2dp"
                    android:background="?attr/selectableItemBackground"/>
            </RelativeLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvResumenApuesta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constrainedHeight="true"
                app:layout_constraintHeight_max="140dp"
                app:layout_constraintTop_toBottomOf="@id/headerCarrito"
                app:layout_constraintBottom_toTopOf="@id/dividerCarrito" />

            <View
                android:id="@+id/dividerCarrito"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#26FFFFFF"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp"
                app:layout_constraintTop_toBottomOf="@id/rvResumenApuesta"
                app:layout_constraintBottom_toTopOf="@id/bottomRowCarrito" />

            <LinearLayout
                android:id="@+id/bottomRowCarrito"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                app:layout_constraintTop_toBottomOf="@id/dividerCarrito"
                app:layout_constraintBottom_toBottomOf="parent">

                <ImageView
                    android:id="@+id/btnMinimizarResumen"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_expand_less"
                    app:tint="#FFFFFF"
                    android:layout_marginEnd="8dp"
                    android:background="?attr/selectableItemBackgroundBorderless"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TOTAL ACUMULADO"
                        android:textColor="#B0BEC5"
                        android:textSize="9sp"/>
                    <TextView
                        android:id="@+id/tvTotalResumen"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$ 0.00"
                        android:textColor="#00E676"
                        android:textSize="22sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFinalizarSeleccion"
                    android:layout_width="wrap_content"
                    android:layout_height="52dp"
                    android:text="LISTO"
                    app:backgroundTint="#00E5FF"
                    android:textColor="#0B132B"
                    android:textStyle="bold"
                    app:cornerRadius="16dp"
                    app:elevation="0dp"
                    android:visibility="gone"
                    tools:visibility="visible"/>
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>