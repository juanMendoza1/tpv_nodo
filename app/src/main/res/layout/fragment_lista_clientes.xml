<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_dashboard_premium">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <View
            android:id="@+id/bgAzulBase"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:background="@drawable/gradient_blue_arena"
            android:alpha="0.20"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/guidelineCenter" />

        <View
            android:id="@+id/bgRojoBase"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:background="@drawable/gradient_red_arena"
            android:alpha="0.20"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintStart_toEndOf="@+id/guidelineCenter"
            app:layout_constraintEnd_toEndOf="parent" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guidelineCenter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.5" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardInfoMesa"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_marginHorizontal="12dp"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#26FFFFFF"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_ghost_gradient">

                <LinearLayout
                    android:id="@+id/bgDueloIncrustado"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:visibility="gone"
                    tools:visibility="visible">

                    <View
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/gradient_blue_arena"
                        android:alpha="0.9" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/gradient_red_arena"
                        android:alpha="0.9" />
                </LinearLayout>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingHorizontal="16dp">

                    <LinearLayout
                        android:id="@+id/layoutLadoIzquierdo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <View
                            android:id="@+id/indicadorEstadoMesa"
                            android:layout_width="4dp"
                            android:layout_height="20dp"
                            android:background="#00E5FF" />

                        <TextView
                            android:id="@+id/tvTituloMesa"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:text="MESA # 01"
                            android:textColor="#FFFFFF"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/containerInfoDueloIncrustado"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:visibility="gone"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        tools:visibility="visible">

                        <TextView
                            android:id="@+id/tvResumenDueloIncrustado"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="5 - 2"
                            android:textColor="#FFFFFF"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:shadowColor="#000000"
                            android:shadowRadius="8" />

                        <TextView
                            android:id="@+id/btnReanudarIncrustado"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="REANUDAR"
                            android:textColor="#00E5FF"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvTituloMesaActual"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="POOL"
                        android:textColor="#BDBDBD"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <LinearLayout
                    android:id="@+id/containerSeleccionVersus"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#E60B132B" android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:visibility="gone"
                    tools:visibility="visible">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="MODO VERSUS"
                            android:textColor="#B0BEC5"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1"/>

                        <TextView
                            android:id="@+id/tvInstruccionSeleccion"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Toca para asignar..."
                            android:textColor="#00E5FF"
                            android:textSize="14sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCancelarVersus"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CANCELAR"
                        android:textColor="#FF5252"
                        android:textSize="11sp"
                        app:rippleColor="#33FF5252"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnIniciarVersus"
                        style="@style/Widget.MaterialComponents.Button"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_marginStart="8dp"
                        android:text="INICIAR"
                        android:textColor="#0B132B"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        app:backgroundTint="#00E5FF"
                        app:cornerRadius="12dp"/>
                </LinearLayout>
            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardDueloEnEspera"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:visibility="gone"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#26FFFFFF"
            app:layout_constraintTop_toBottomOf="@id/cardInfoMesa"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_banner_duelo_pro"
                android:orientation="horizontal"
                android:paddingStart="20dp"
                android:paddingEnd="12dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AZUL"
                    android:textColor="#00E5FF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="14dp"
                    android:layout_marginEnd="14dp"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚔️ VS"
                        android:textColor="#80FFFFFF"
                        android:textSize="9sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvResumenDuelo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 - 0"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:includeFontPadding="false"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ROJO"
                    android:textColor="#FF5252"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnReanudarDuelo"
                    style="@style/Widget.MaterialComponents.Button.Icon"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="16dp"
                    app:backgroundTint="#FFFFFF"
                    app:cornerRadius="20dp"
                    app:icon="@drawable/ic_play_arrow"
                    app:iconPadding="0dp"
                    app:iconSize="22dp"
                    app:iconTint="#0B132B"
                    app:elevation="0dp"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvEmptyMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No hay clientes registrados"
            android:textSize="16sp"
            android:textColor="#B0BEC5"
            android:visibility="visible"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cardInfoMesa" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvClientes"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"
            android:paddingHorizontal="12dp"
            android:paddingTop="12dp"
            android:paddingBottom="80dp"
            android:clipToPadding="false"
            android:layout_marginEnd="70dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cardDueloEnEspera"
            tools:listitem="@layout/item_cliente" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardResumenPago"
            android:layout_marginTop="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@android:color/transparent"
            app:strokeWidth="1dp"
            app:strokeColor="#33FFFFFF"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cardInfoMesa"
            app:layout_constraintVertical_bias="1.0"
            app:layout_constrainedHeight="true"
            android:layout_marginBottom="0dp"
            tools:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_ghost_gradient"
                android:orientation="vertical"
                android:paddingTop="16dp"
                android:paddingHorizontal="16dp"
                android:paddingBottom="32dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingBottom="8dp">

                    <ImageView
                        android:id="@+id/btnMinimizarPago"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_expand_less"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        app:tint="#FFFFFF"
                        android:layout_centerVertical="true"/>

                    <TextView
                        android:id="@+id/tvNombreClientePago"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/btnMinimizarPago"
                        android:layout_toStartOf="@id/btnCerrarResumen"
                        android:text="DETALLE DE CONSUMO"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:textColor="#FFFFFF"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="8dp"
                        android:ellipsize="end"
                        android:maxLines="1"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCerrarResumen"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="CERRAR"
                        android:textColor="#FF5252"
                        android:textSize="11sp" />
                </RelativeLayout>

                <LinearLayout
                    android:id="@+id/layoutDetallePagoColapsable"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    android:orientation="vertical"
                    tools:visibility="visible">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvItemsCuenta"
                        android:layout_width="match_parent"
                        android:layout_height="140dp"
                        android:paddingVertical="4dp"
                        tools:listitem="@layout/item_detalle_ticket" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#26FFFFFF"
                        android:layout_marginVertical="12dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingTop="8dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TOTAL PENDIENTE"
                            android:textSize="10sp"
                            android:textColor="#B0BEC5"
                            android:letterSpacing="0.05"/>

                        <TextView
                            android:id="@+id/tvMontoTotalResumen"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="$ 0.00"
                            android:textColor="#FFFFFF"
                            android:textSize="26sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnEjecutarPagoVisual"
                        android:layout_width="wrap_content"
                        android:layout_height="56dp"
                        android:text="PAGAR CUENTA"
                        app:backgroundTint="#00E5FF"
                        android:textColor="#0B132B"
                        android:textStyle="bold"
                        app:cornerRadius="16dp"
                        app:elevation="0dp"
                        app:iconTint="#0B132B"
                        app:icon="@drawable/ic_payments"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/panelComandos"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="100dp"
        android:layout_marginEnd="6dp"
        android:layout_marginBottom="24dp"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardCornerRadius="32dp"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="#26FFFFFF">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_ghost_gradient"
            android:orientation="vertical"
            android:paddingHorizontal="6dp"
            android:paddingVertical="8dp"
            android:gravity="center_horizontal">

            <ImageButton
                android:id="@+id/btnMainAction"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/bg_circle_neon_btn"
                android:backgroundTint="#332962FF"
                android:src="@drawable/ic_add"
                android:scaleType="centerInside"
                app:tint="#2962FF" />

            <androidx.core.widget.NestedScrollView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:scrollbars="none"
                android:overScrollMode="never">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnModoDuelo"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:layout_marginTop="4dp"
                        android:visibility="gone"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:padding="0dp"
                        app:iconSize="30dp"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        app:icon="@drawable/ic_versus"
                        app:iconTint="#B388FF"
                        app:rippleColor="#33FFFFFF" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnRegistrar"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:layout_marginTop="4dp"
                        android:visibility="gone"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:padding="0dp"
                        app:iconSize="30dp"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        app:icon="@drawable/ic_person_add"
                        app:iconTint="#00E5FF"
                        app:rippleColor="#33FFFFFF" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPagarTodo"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:layout_marginTop="4dp"
                        android:visibility="gone"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:padding="0dp"
                        app:iconSize="30dp"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        app:icon="@drawable/ic_receipt"
                        app:iconTint="#FF5252"
                        app:rippleColor="#33FFFFFF" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnHistorial"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:layout_marginTop="4dp"
                        android:visibility="gone"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:padding="0dp"
                        app:iconSize="30dp"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        app:icon="@drawable/ic_history"
                        app:iconTint="#B0BEC5"
                        app:rippleColor="#33FFFFFF" />

                </LinearLayout>
            </androidx.core.widget.NestedScrollView>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>