<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <View
        android:id="@+id/bgArenaBase"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_arena_dark_pattern" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guidelineVAR"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.0" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guidelineCenter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.5" />

    <View
        android:id="@+id/bgAzulGarena"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:alpha="0.4"
        android:background="@drawable/gradient_blue_arena"
        app:layout_constraintEnd_toStartOf="@+id/guidelineCenter"
        app:layout_constraintStart_toEndOf="@id/guidelineVAR" />

    <View
        android:id="@+id/bgRojoGarena"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:alpha="0.4"
        android:background="@drawable/gradient_red_arena"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/guidelineCenter" />

    <WebView
        android:id="@+id/webViewCamara"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#000000"
        android:visibility="gone"
        android:elevation="2dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/guidelineVAR"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ScrollView
        android:id="@+id/scrollAccionesLateral"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="24dp"
        android:elevation="12dp"
        android:scrollbars="none"
        app:layout_constrainedHeight="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/panelAccionesLateral"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/fabSeleccionarMunicion"
                style="@style/Widget.MaterialComponents.Button.Icon"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginBottom="8dp"
                app:backgroundTint="#4D000000"
                app:cornerRadius="28dp"
                app:icon="@drawable/ic_shopping_bag"
                app:iconSize="26dp"
                app:iconTint="#FFD600"
                app:strokeColor="#FFD600"
                app:strokeWidth="1.5dp" />

            <LinearLayout
                android:id="@+id/containerBolsaMinimizada"
                android:layout_width="56dp"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_badge_monto"
                android:backgroundTint="#4D000000"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingVertical="6dp">
                <TextView
                    android:id="@+id/tvProductoEnJuego"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$0"
                    android:textColor="#FFD600"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <FrameLayout
                android:id="@+id/btnVerPendientes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:clickable="true"
                android:focusable="true">

                <com.google.android.material.button.MaterialButton
                    style="@style/Widget.MaterialComponents.Button.Icon"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:clickable="false"
                    android:focusable="false"
                    app:backgroundTint="#4D000000"
                    app:cornerRadius="28dp"
                    app:icon="@drawable/ic_shopping_basket"
                    app:iconSize="26dp"
                    app:iconTint="#FF1744"
                    app:strokeColor="#4DFF1744"
                    app:strokeWidth="1.5dp" />

                <TextView
                    android:id="@+id/tvBadgePendientes"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="top|end"
                    android:background="@drawable/bg_circle_red"
                    android:gravity="center"
                    android:text="3"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    tools:visibility="visible" />
            </FrameLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnHistorialDuelo"
                style="@style/Widget.MaterialComponents.Button.Icon"
                android:layout_width="56dp"
                android:layout_height="56dp"
                app:backgroundTint="#4D000000"
                app:cornerRadius="28dp"
                app:icon="@drawable/ic_history"
                app:iconSize="26dp"
                app:iconTint="#FFD600"
                app:strokeColor="#4DFFD600"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnConfigReglas"
                style="@style/Widget.MaterialComponents.Button.Icon"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginBottom="16dp"
                app:backgroundTint="#4D000000"
                app:cornerRadius="28dp"
                app:icon="@drawable/ic_settings"
                app:iconSize="24dp"
                app:iconTint="#FFFFFF"
                app:strokeColor="#4DFFFFFF"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnModoTactico"
                style="@style/Widget.MaterialComponents.Button.Icon"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginBottom="16dp"
                app:backgroundTint="#4D00E5FF"
                app:cornerRadius="28dp"
                app:icon="@drawable/ic_track_changes"
                app:iconSize="26dp"
                app:iconTint="#00E5FF"
                app:strokeColor="#00E5FF"
                app:strokeWidth="1.5dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnVAR"
                style="@style/Widget.MaterialComponents.Button.Icon"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginBottom="16dp"
                app:backgroundTint="#4DFF1744"
                app:cornerRadius="28dp"
                app:icon="@drawable/ic_videocam"
                app:iconSize="26dp"
                app:iconTint="#FFFFFF"
                app:strokeColor="#FF1744"
                app:strokeWidth="1.5dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnExpandirArena"
                style="@style/Widget.MaterialComponents.Button.Icon"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginBottom="16dp"
                app:backgroundTint="#4D000000"
                app:cornerRadius="28dp"
                app:icon="@drawable/ic_fullscreen"
                app:iconSize="26dp"
                app:iconTint="#FFFFFF"
                app:strokeColor="#4DFFFFFF"
                app:strokeWidth="1dp" />

        </LinearLayout>
    </ScrollView>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutContenidoArena"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginEnd="16dp"
        android:elevation="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/scrollAccionesLateral"
        app:layout_constraintStart_toEndOf="@id/guidelineVAR"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.core.widget.NestedScrollView
            android:id="@+id/scrollGuerreros"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="16dp"
            android:clipToPadding="false"
            android:fillViewport="true"
            app:layout_constraintBottom_toTopOf="@id/btnFinalizarDuelo"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <HorizontalScrollView
                    android:id="@+id/scrollMarcadores"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:elevation="10dp"
                    android:fillViewport="true"
                    android:scrollbars="none">

                    <LinearLayout
                        android:id="@+id/containerMarcadoresDinamicos"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_scoreboard_frame"
                        android:backgroundTint="#26000000"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:paddingHorizontal="6dp"
                        android:paddingVertical="4dp" />
                </HorizontalScrollView>

                <com.google.android.flexbox.FlexboxLayout
                    android:id="@+id/containerGuerrerosDinamicos"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:paddingHorizontal="24dp"
                    app:flexWrap="wrap"
                    app:justifyContent="center" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFinalizarDuelo"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="200dp"
            android:layout_height="50dp"
            android:layout_marginBottom="24dp"
            android:backgroundTint="#1A000000"
            android:letterSpacing="0.1"
            android:text="FINALIZAR BATALLA"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            app:cornerRadius="25dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:strokeColor="#FFD600"
            app:strokeWidth="1.5dp" />

        <TextView
            android:id="@+id/tvReglaActiva"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginBottom="32dp"
            android:alpha="0.6"
            android:fontFamily="sans-serif-condensed-medium"
            android:letterSpacing="0.1"
            android:text="REGLA: NO DEFINIDA"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <LinearLayout
        android:id="@+id/panelConfigDeslizable"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F2080808"
        android:elevation="40dp"
        android:orientation="vertical"
        android:visibility="gone"
        android:translationX="1000dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="REGLAS Y SEGURIDAD"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:textSize="12sp"
            android:textStyle="bold"
            android:paddingTop="18dp"
            android:paddingBottom="12dp" />

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingBottom="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="MODALIDAD DE COBRO"
                    android:textColor="#80FFFFFF"
                    android:textSize="14sp"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="16dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnReglaGanador"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:text="GANA BANDO (Reparto Resto)"
                    android:textColor="#FFFFFF"
                    android:layout_marginBottom="8dp"
                    app:strokeColor="#4DFFFFFF" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnReglaTodos"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:text="REPARTO EQUITATIVO (Todos)"
                    android:textColor="#FFFFFF"
                    android:layout_marginBottom="8dp"
                    app:strokeColor="#4DFFFFFF" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnReglaUltimo"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:text="EL ÚLTIMO PAGA TODO"
                    android:textColor="#FFFFFF"
                    android:layout_marginBottom="16dp"
                    app:strokeColor="#4DFFFFFF" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="CONTROL DE MARCADOR"
                    android:textColor="#80FFFFFF"
                    android:textSize="14sp"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="16dp" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="#1AFFFFFF"
                    app:contentPadding="24dp"
                    app:cardCornerRadius="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Solicitar PIN para anotar"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp" />

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switchRequierePin"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:thumbTint="@color/white"
                            app:trackTint="#565654" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCerrarConfig"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="CERRAR AJUSTES"
            app:backgroundTint="#565654"
            android:textColor="#000000"
            android:layout_margin="32dp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/panelHistorialDeslizable"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F2080808"
        android:elevation="40dp"
        android:orientation="vertical"
        android:padding="12dp"
        android:visibility="gone"
        android:translationX="1000dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="HISTORIAL DUELO"
            android:textColor="#565654"
            android:gravity="center"
            android:textSize="12sp"
            android:textStyle="bold"
            android:paddingTop="16dp"
            android:paddingBottom="16dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvHistorialLateral"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCerrarHistorial"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="VOLVER"
            app:backgroundTint="#565654"
            android:textColor="#000000"
            android:layout_marginVertical="8dp" />
    </LinearLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/panelDespachoDeslizable"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#E6050505"
        android:elevation="50dp"
        android:visibility="gone"
        android:translationX="1000dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:id="@+id/tvTituloDespacho"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="DESPACHO PEDIDO"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginTop="32dp"
            android:layout_marginHorizontal="24dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvSubtituloDespacho"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Toca un producto para marcar su entrega"
            android:textColor="#80FFFFFF"
            android:gravity="center"
            android:textSize="10sp"
            android:layout_marginTop="4dp"
            android:layout_marginHorizontal="24dp"
            android:textStyle="italic"
            app:layout_constraintTop_toBottomOf="@id/tvTituloDespacho"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <View
            android:id="@+id/divisorDespacho"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#1AFFFFFF"
            android:layout_marginTop="16dp"
            android:layout_marginHorizontal="24dp"
            app:layout_constraintTop_toBottomOf="@id/tvSubtituloDespacho" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvDespachoLateral"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:clipToPadding="false"
            android:paddingTop="8dp"
            android:paddingHorizontal="12dp"
            app:layout_constraintTop_toBottomOf="@id/divisorDespacho"
            app:layout_constraintBottom_toTopOf="@id/btnEntregarTodoLateral"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEntregarTodoLateral"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:text="ENTREGAR PRODUCTO COMPLETO"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            app:strokeColor="#FFFFFF"
            app:strokeWidth="2dp"
            android:layout_marginHorizontal="24dp"
            android:layout_marginBottom="8dp"
            app:layout_constraintBottom_toTopOf="@id/btnCerrarDespacho"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCerrarDespacho"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:text="VOLVER"
            android:textColor="#B3FFFFFF"
            android:letterSpacing="0.1"
            app:strokeColor="#4DFFFFFF"
            app:strokeWidth="1dp"
            android:layout_marginHorizontal="24dp"
            android:layout_marginBottom="24dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/lottieCelebration"
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:elevation="50dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:lottie_autoPlay="false"
        app:lottie_rawRes="@raw/donald" />

</androidx.constraintlayout.widget.ConstraintLayout>