<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:layout_weight="1"
    android:layout_margin="8dp"
    app:cardBackgroundColor="@android:color/transparent"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeWidth="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1A000000"
        android:padding="6dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:paddingHorizontal="4dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true">

                <TextView
                    android:id="@+id/tvLabelEquipoDinamico"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="EQUIPO A"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="14sp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MESA:"
                        android:textColor="#FFFFFF"
                        android:textSize="9sp"
                        android:layout_marginEnd="4dp"/>
                    <TextView
                        android:id="@+id/tvSaldoEquipo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$0"
                        android:textColor="#FFD600"
                        android:textStyle="bold"
                        android:textSize="10sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="EXTRA:"
                        android:textColor="#FFFFFF"
                        android:textSize="9sp"
                        android:layout_marginEnd="4dp"/>
                    <TextView
                        android:id="@+id/tvSaldoExtra"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$0"
                        android:textColor="#00E5FF"
                        android:textStyle="bold"
                        android:textSize="10sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/containerMalasVisual"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MALAS: "
                    android:textColor="#FF5252"
                    android:textStyle="bold"
                    android:textSize="11sp"/>

                <TextView
                    android:id="@+id/tvMalasValor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#FF1744"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:includeFontPadding="false"/>
            </LinearLayout>
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:weightSum="10"
            android:layout_marginBottom="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFalta"
                style="@style/Widget.MaterialComponents.Button.Icon"
                android:layout_width="0dp"
                android:layout_weight="2.5"
                android:layout_height="45dp"
                app:backgroundTint="#1AFF1744"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_remove"
                app:iconTint="#FF1744"
                app:strokeColor="#FF1744"
                app:strokeWidth="2dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="5"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PUNTOS"
                    android:textColor="#BDBDBD"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"/>

                <TextView
                    android:id="@+id/tvScoreDinamico"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textAlignment="center"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-black"
                    app:autoSizeTextType="uniform"
                    app:autoSizeMaxTextSize="50sp" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAnotarBola"
                style="@style/Widget.MaterialComponents.Button.Icon"
                android:layout_width="0dp"
                android:layout_weight="2.5"
                android:layout_height="45dp"
                app:backgroundTint="#1A00E5FF"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_add"
                app:iconTint="#00E5FF"
                app:strokeColor="#00E5FF"
                app:strokeWidth="2dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutInventarioBolas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="4dp">

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#33FFFFFF"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BOLAS ANOTADAS"
                android:textColor="#BDBDBD"
                android:textSize="8sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="4dp"/>

            <HorizontalScrollView
                android:id="@+id/scrollBolas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="65dp"
                android:background="#0DFFFFFF"
                android:paddingVertical="4dp"
                android:clipToPadding="false"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/containerBolasIngresadas"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical|start"
                    android:paddingHorizontal="6dp" />

            </HorizontalScrollView>
        </LinearLayout>

        <FrameLayout
            android:id="@+id/layoutFondoSwipe"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_boton_cyan_garena"
            android:backgroundTint="#33000000">

            <TextView
                android:id="@+id/tvTextoSwipe"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="👉 DESLIZA PARA GANAR"
                android:textColor="#FFD600"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"/>

            <SeekBar
                android:id="@+id/swipeToWin"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:max="100"
                android:progress="0"
                android:thumbTint="#FFD600"
                android:progressTint="@android:color/transparent"
                android:progressBackgroundTint="@android:color/transparent"
                android:splitTrack="false"/>
        </FrameLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>