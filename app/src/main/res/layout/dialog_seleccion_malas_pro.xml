<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:background="#E6000000">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <ImageButton
            android:id="@+id/btnCerrarDialog"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_alignParentEnd="true"
            android:layout_marginTop="30dp"
            android:layout_marginEnd="20dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_close"
            app:tint="#FFFFFF" />
    </RelativeLayout>

    <View android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="FALTAS COMETIDAS"
        android:textColor="#FF1744"
        android:textSize="20sp"
        android:textStyle="bold"
        android:letterSpacing="0.1" />

    <TextView
        android:id="@+id/tvCantidadMalas"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0"
        android:textColor="#FFFFFF"
        android:textSize="100sp"
        android:textStyle="bold"
        android:layout_marginTop="10dp" />

    <SeekBar
        android:id="@+id/sliderMalas"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="50dp"
        android:layout_marginTop="30dp"
        android:max="100"
        android:progress="0"
        android:progressTint="#FF1744"
        android:thumbTint="#FF1744" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Desliza para ajustar (0 - 100)"
        android:textColor="#88FFFFFF"
        android:textSize="12sp"
        android:layout_marginTop="10dp" />

    <View android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnConfirmarMalas"
        style="@style/Widget.MaterialComponents.Button"
        android:layout_width="wrap_content"
        android:layout_height="55dp"
        android:layout_marginBottom="40dp"
        android:paddingHorizontal="50dp"
        android:text="APLICAR"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:textSize="16sp"
        android:letterSpacing="0.1"
        app:backgroundTint="#FF1744"
        app:cornerRadius="28dp" />
</LinearLayout>