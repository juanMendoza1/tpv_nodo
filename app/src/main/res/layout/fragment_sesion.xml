<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_dashboard_premium">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeColor="#26FFFFFF"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_ghost_gradient"
                    android:orientation="vertical"
                    android:padding="32dp">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_table_bar"
                        app:tint="#00E5FF" />

                    <LinearLayout
                        android:id="@+id/layoutActivacion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Terminal no vinculada.\nEscanea el QR de activación."
                            android:textAlignment="center"
                            android:textColor="#B0BEC5" />

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardCamera"
                            android:layout_width="match_parent"
                            android:layout_height="250dp"
                            android:layout_marginTop="20dp"
                            app:cardBackgroundColor="@android:color/transparent"
                            app:cardCornerRadius="16dp"
                            app:strokeColor="#3300E5FF"
                            app:strokeWidth="1dp">

                            <FrameLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent">

                                <androidx.camera.view.PreviewView
                                    android:id="@+id/previewView"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    app:scaleType="fillCenter" />

                                <com.google.android.material.progressindicator.CircularProgressIndicator
                                    android:id="@+id/loadingScanner"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center"
                                    android:indeterminate="true"
                                    android:visibility="gone"
                                    app:indicatorColor="#00E5FF" />
                            </FrameLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnEscanearQR"
                            android:layout_width="match_parent"
                            android:layout_height="60dp"
                            android:layout_marginTop="32dp"
                            app:backgroundTint="#00E5FF"
                            android:text="ESCANEAR QR"
                            android:textColor="#0B132B"
                            app:cornerRadius="16dp"
                            app:icon="@drawable/ic_qr_code"
                            app:iconTint="#0B132B" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layoutLogin"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="visible">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="280dp"
                            android:layout_marginTop="2dp">

                            <androidx.recyclerview.widget.RecyclerView
                                android:id="@+id/rvSlots"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@android:color/transparent"
                                android:padding="4dp" />

                            <com.google.android.material.progressindicator.CircularProgressIndicator
                                android:id="@+id/loadingSlots"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:indeterminate="true"
                                android:visibility="gone"
                                app:indicatorColor="#00E5FF" />
                        </FrameLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilPin"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:hint="Ingrese su PIN"
                            android:textColorHint="#90A4AE"
                            app:boxStrokeColor="#00E5FF"
                            app:hintTextColor="#00E5FF"
                            android:visibility="gone"
                            app:passwordToggleEnabled="true"
                            app:passwordToggleTint="#B0BEC5">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etPinLogin"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:inputType="numberPassword"
                                android:letterSpacing="0.3"
                                android:maxLength="6"
                                android:textColor="#FFFFFF"
                                android:textSize="20sp" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnLogin"
                            android:layout_width="match_parent"
                            android:layout_height="60dp"
                            android:layout_marginTop="20dp"
                            app:backgroundTint="#00E5FF"
                            android:text="ENTRAR"
                            android:textColor="#0B132B"
                            android:textStyle="bold"
                            android:visibility="gone"
                            app:cornerRadius="16dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layoutComandos"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:visibility="gone"
                        android:paddingTop="16dp"
                        android:paddingBottom="8dp">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:layout_marginBottom="16dp"
                            app:cardBackgroundColor="@android:color/transparent"
                            app:cardCornerRadius="32dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="1dp"
                            app:strokeColor="#26FFFFFF">

                            <FrameLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_ghost_gradient">

                                <ImageView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_person"
                                    app:tint="#00E5FF" />
                            </FrameLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="OPERARIO"
                            android:textColor="#B0BEC5"
                            android:textSize="10sp"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.15"
                            android:layout_marginBottom="4dp"/>

                        <TextView
                            android:id="@+id/tvUsuarioActivo"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textAlignment="center"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:fontFamily="sans-serif-black"
                            android:letterSpacing="0.05"
                            android:layout_marginBottom="18dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnCerrarSesion"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="match_parent"
                            android:layout_height="64dp"
                            android:text="SALIR"
                            android:textColor="#FF5252"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-condensed"
                            android:letterSpacing="0.1"
                            app:strokeColor="#FF5252"
                            app:strokeWidth="2dp"
                            app:cornerRadius="20dp"
                            app:rippleColor="#33FF5252"
                            app:icon="@drawable/ic_exit_to_app"
                            app:iconGravity="textStart"
                            app:iconTint="#FF5252" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>
</FrameLayout>